# =========================================================================
# SHIMPIMILAN Environment Configuration Template
# =========================================================================

# --- DATABASE CONFIGURATION ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/shimpimilan_prod?useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_secure_db_password

# --- JWT AUTHENTICATION ---
# Generate a secure 512-bit key (e.g., using openssl rand -hex 64)
APP_JWT_SECRET=your_secure_jwt_secret_key_here
APP_JWT_EXPIRATION_MS=86400000

# --- RAZORPAY PAYMENT GATEWAY ---
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# --- EMAIL CONFIGURATION (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password

# --- SERVER CONFIGURATION ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
